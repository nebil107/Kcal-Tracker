# --- KalorienPlaner-Sync: Konfiguration -------------------------------------
# Kopiere diese Datei nach ".env" und trage echte Werte ein.
# (In Portainer kannst du diese Variablen auch direkt im Stack-Formular setzen.)

# PFLICHT: geheimer API-Schlüssel. Lang & zufällig wählen!
# Denselben Wert trägst du in der App unter „Cloud-Sync" ein.
# Beispiel zum Erzeugen (Linux/Mac):   openssl rand -base64 32
SYNC_API_KEY=BITTE-EINEN-LANGEN-ZUFALLSWERT-EINTRAGEN

# PFLICHT für HTTPS: deine Domain, die per DNS A-Record auf den VPS zeigt.
SYNC_DOMAIN=sync.deinedomain.de

# OPTIONAL: Kontakt-E-Mail für Let's Encrypt.
ACME_EMAIL=

# OPTIONAL: maximale Upload-Größe in Bytes (Standard: 50 MB).
SYNC_MAX_BODY_BYTES=52428800
